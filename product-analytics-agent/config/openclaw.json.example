{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": "anthropic/claude-sonnet-4-5",
    },
    "list": [
      {
        "id": "product-analytics",
        "name": "Product Analytics Agent",
        "workspace": "~/.openclaw/workspace-product-analytics",
        "agentDir": "~/.openclaw/agents/product-analytics/agent",
        "default": false,
        "model": "anthropic/claude-sonnet-4-5",
        "heartbeat": {
          "every": "1h",
          "target": "slack",
          "prompt": "Read HEARTBEAT.md if it exists. Check product metrics, generate insights, and update dashboards. If nothing needs attention, reply HEARTBEAT_OK.",
        },
        "sandbox": {
          "mode": "all",
          "scope": "agent",
        },
        "tools": {
          "allow": [
            "read",
            "memory_search",
            "memory_get",
            "cron_list",
            "cron_run",
            "sessions_list",
            "sessions_history",
            "sessions_send",
          ],
          "deny": [
            "write",
            "edit",
            "apply_patch",
            "exec",
            "browser",
            "canvas",
            "nodes",
          ],
        },
      },
    ],
  },
  "bindings": [
    {
      "agentId": "product-analytics",
      "match": {
        "channel": "slack",
        "accountId": "product-analytics-bot",
      },
    },
  ],
  "channels": {
    "slack": {
      "accounts": {
        "product-analytics-bot": {
          "token": "xoxb-YOUR-SLACK-BOT-TOKEN",
        },
      },
    },
  },
  "cron": {
    "enabled": true,
    "sessionRetention": "7d",
  },
  "skills": {
    "entries": {
      "metric-tracker": {
        "enabled": true,
      },
      "insight-generator": {
        "enabled": true,
      },
      "dashboard-builder": {
        "enabled": true,
      },
    },
  },
}
