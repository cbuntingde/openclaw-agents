{
    "agents": {
        "list": [
            {
                "id": "main",
                "name": "🐾 OpenClaw",
                "workspace": "~/.openclaw/workspace-main",
                "model": "anthropic/claude-sonnet-4-5",
                "default": true
            },
            {
                "id": "planner",
                "name": "🧠 Planner",
                "workspace": "~/.openclaw/workspace-planner",
                "model": "anthropic/claude-sonnet-4-5"
            },
            {
                "id": "ideator",
                "name": "💡 Ideator",
                "workspace": "~/.openclaw/workspace-ideator",
                "model": "anthropic/claude-sonnet-4-5"
            },
            {
                "id": "critic",
                "name": "🎯 Critic",
                "workspace": "~/.openclaw/workspace-critic",
                "model": "anthropic/claude-sonnet-4-5"
            },
            {
                "id": "surveyor",
                "name": "📚 Surveyor",
                "workspace": "~/.openclaw/workspace-surveyor",
                "model": "anthropic/claude-sonnet-4-5"
            },
            {
                "id": "coder",
                "name": "💻 Coder",
                "workspace": "~/.openclaw/workspace-coder",
                "model": "anthropic/claude-sonnet-4-5"
            },
            {
                "id": "writer",
                "name": "✍️ Writer",
                "workspace": "~/.openclaw/workspace-writer",
                "model": "anthropic/claude-sonnet-4-5"
            },
            {
                "id": "reviewer",
                "name": "🔍 Reviewer",
                "workspace": "~/.openclaw/workspace-reviewer",
                "model": "anthropic/claude-sonnet-4-5"
            },
            {
                "id": "scout",
                "name": "📰 Scout",
                "workspace": "~/.openclaw/workspace-scout",
                "model": "anthropic/claude-sonnet-4-5"
            }
        ]
    },
    "bindings": [
        {
            "agentId": "main",
            "match": {
                "channel": "whatsapp",
                "peer": {
                    "kind": "group",
                    "id": "YOUR_GROUP_ID@g.us"
                }
            }
        }
    ],
    "channels": {
        "whatsapp": {
            "dmPolicy": "pairing",
            "groups": {
                "*": {
                    "requireMention": true
                }
            }
        }
    }
}