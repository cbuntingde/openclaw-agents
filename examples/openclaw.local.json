            },
            {
                "id": "reviewer",
                "name": "🔍 Reviewer",
                "workspace": "~/.openclaw/workspace-reviewer",
                "model": "zai/glm-5",
                "identity": {
                    "name": "🔍 Reviewer"
                }
            },
            {
                "id": "scout",
                "name": "📰 Scout",
                "workspace": "~/.openclaw/workspace-scout",
                "model": "zai/glm-5",
                "identity": {
                    "name": "📰 Scout"
                }
            }
        ]
    },
    "tools": {
        "agentToAgent": {
            "enabled": true,
            "allow": [
                {
                    "from": "*",
                    "to": "planner"
                },
                {
                    "from": "planner",
                    "to": "*"
                },
                {
                    "from": "ideator",
                    "to": "critic"
                },
                {
                    "from": "critic",
                    "to": "ideator"
                },
                {
                    "from": "writer",
                    "to": "reviewer"
                },
                {
                    "from": "reviewer",
                    "to": "writer"
                }
            ]
        }
    }
}